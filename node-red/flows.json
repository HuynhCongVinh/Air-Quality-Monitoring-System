    {
        "id": "08197040ee9766b5",
        "type": "function",
        "z": "55f26fab05f1bbb4",
        "name": "Tính toán AQI",
        "func": "var pm25 = Number(msg.payload[\"pm2.5\"]);\nvar aqi = 0;\n\n// Công thức tính AQI chuẩn cho PM2.5 (6 mức)\nif (pm25 <= 12) {\n    aqi = ((50 - 0) / (12 - 0)) * (pm25 - 0) + 0;\n} else if (pm25 <= 35.4) {\n    aqi = ((100 - 51) / (35.4 - 12.1)) * (pm25 - 12.1) + 51;\n} else if (pm25 <= 55.4) {\n    aqi = ((150 - 101) / (55.4 - 35.5)) * (pm25 - 35.5) + 101;\n} else if (pm25 <= 150.4) {\n    aqi = ((200 - 151) / (150.4 - 55.5)) * (pm25 - 55.5) + 151;\n} else if (pm25 <= 250.4) {\n    aqi = ((300 - 201) / (250.4 - 150.5)) * (pm25 - 150.5) + 201;\n} else {\n    aqi = ((500 - 301) / (500.4 - 250.5)) * (pm25 - 250.5) + 301;\n}\n\nmsg.payload = Math.round(aqi); // Làm tròn số AQI\nmsg.topic = \"Chỉ số AQI\";\nreturn msg;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 520,
        "y": 440,
        "wires": [
            [
                "c9523e24bab8f793",
                "48b378fef8b653cc"
            ]
        ]

        "id": "3f744ea1ce87478b",
        "type": "function",
        "z": "55f26fab05f1bbb4",
        "name": "Xử lý dự báo PM2.5",
        "func": "var data = msg.payload;\nif (typeof data === 'string') data = JSON.parse(data);\n\nif (data && data.target_pm25 !== undefined) {\n    msg.payload = Number(data.target_pm25); // Ép về kiểu số\n    msg.topic = \"Dự báo (AI)\";\n    return msg;\n}",
